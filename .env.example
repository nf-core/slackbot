# Slack App credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token  # Socket mode (local dev)

# GitHub (fine-grained PAT with read:org scope)
GITHUB_TOKEN=ghp_your-token
GITHUB_ORG=nf-core

# DynamoDB
DYNAMODB_TABLE=nf-core-bot
DYNAMODB_ENDPOINT=http://localhost:8000  # local DynamoDB; unset for AWS
AWS_REGION=eu-west-1

# Permissions
CORE_TEAM_USERGROUP_HANDLE=core-team
